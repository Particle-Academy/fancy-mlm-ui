{
  "name": "@particle-academy/fancy-mlm-ui",
  "version": "0.1.1",
  "description": "React UI for Fancy MLM — downline tree, commission statement, and rank progress. Controlled, JSON-friendly, agent-driveable.",
  "keywords": [
    "mlm",
    "referral",
    "downline",
    "react",
    "tailwind",
    "particle-academy"
  ],
  "homepage": "https://github.com/Particle-Academy/fancy-mlm-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-mlm-ui.git"
  },
  "bugs": "https://github.com/Particle-Academy/fancy-mlm-ui/issues",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@particle-academy/react-fancy": ">=4.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@particle-academy/react-fancy": "^4.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
